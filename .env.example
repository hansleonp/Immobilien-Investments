# Supabase (Settings → API im Supabase-Dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# E-Mail-Import (M11): Secret für den Inbound-Webhook
# (?secret=… oder Header x-inbound-secret — frei wählbarer, langer Zufallswert)
EMAIL_INBOUND_SECRET=
# UUID des Users, dem eingehende Inserate zugeordnet werden
# (Supabase-Dashboard → Authentication → Users)
EMAIL_INBOUND_USER_ID=
# Service-Role-Key für den Webhook (Settings → API) — umgeht RLS, geheim halten!
SUPABASE_SERVICE_ROLE_KEY=

# KI-Features (M12)
ANTHROPIC_API_KEY=
